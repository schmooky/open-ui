---
import Base from './Base.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import { GUIDES_NAV, DOCS_NAV, RECIPES_NAV, type NavSection } from '../content/nav.ts';

type Section = 'guides' | 'docs' | 'recipes';

interface Props {
  title?: string;
  description?: string;
  section?: Section;
  eyebrow?: string;
  frontmatter?: {
    title?: string;
    description?: string;
    section?: Section;
    eyebrow?: string;
  };
}

const props = Astro.props as Props;
const fm = props.frontmatter ?? {};
const title = props.title ?? fm.title ?? 'open-ui';
const description =
  props.description ?? fm.description ?? `${title} — open-ui documentation.`;
const section = (props.section ?? fm.section ?? 'guides') as Section;
const eyebrow = props.eyebrow ?? fm.eyebrow;
const pathname = Astro.url.pathname;

const navMap: Record<Section, NavSection[]> = {
  guides: GUIDES_NAV,
  docs: DOCS_NAV,
  recipes: RECIPES_NAV,
};
const nav = navMap[section] ?? [];
---
<Base title={`${title} · open-ui`} description={description}>
  <div class="container grid gap-10 py-12 md:grid-cols-[230px_minmax(0,1fr)]">
    {nav.length > 0 && <DocsSidebar nav={nav} pathname={pathname} />}
    <article class:list={["prose-docs min-w-0 max-w-3xl animate-fade-in", { 'md:col-span-2 mx-auto': nav.length === 0 }]}>
      {eyebrow && (
        <div class="mb-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-primary">
          {eyebrow}
        </div>
      )}
      <h1 class="mb-6 text-4xl font-semibold tracking-tight">{title}</h1>
      <slot />
    </article>
  </div>
</Base>
